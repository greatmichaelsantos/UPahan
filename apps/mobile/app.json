{
  "expo": {
    "name": "UPahan",
    "newArchEnabled": true,
    "slug": "upahan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2E7D72"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "upahan",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.upahan.app"
    },
    "android": {
      "package": "com.upahan.app",
      "adaptiveIcon": {
        "backgroundColor": "#2E7D72"
      }
    },
    "plugins": [
      "expo-font",
      "expo-asset"
    ]
  }
}
